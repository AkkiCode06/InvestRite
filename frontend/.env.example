# Copy this file to .env and fill in real values
# Firebase config — get these from Firebase Console → Project Settings → Your apps

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Backend URL — only needed when frontend and backend are on different hosts
# e.g. Netlify frontend + Railway backend
# Leave blank when running locally (Vite proxies /api to localhost:3001)
VITE_API_BASE_URL=
