# Copy this file to .env and fill in real values
# Never commit .env to Git

NODE_ENV=development
PORT=3001

# Gmail SMTP (Google Account → Security → App Passwords)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# JWT (only used for legacy middleware, can be any random string)
JWT_SECRET=change-me-to-something-random

# Set this to your Netlify URL when deploying (for CORS)
FRONTEND_URL=https://your-app.netlify.app
